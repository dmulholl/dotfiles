#!/usr/bin/env python3
# ──────────────────────────────────────────────────────────────────────────────
# Prints a centered title across the width of the terminal.
# ──────────────────────────────────────────────────────────────────────────────

import shutil
import sys
import math

helptext = """
Usage:
  termtitle <text>
  termtitle <line-color> <text>
  termtitle <line-color> <text-color> <text>
""".strip()

def get_color_code(arg):
    if arg == "black":
        return "\x1B[30m"
    elif arg == "red":
        return "\x1B[31m"
    elif arg == "green":
        return "\x1B[32m"
    elif arg == "yellow":
        return "\x1B[33m"
    elif arg == "blue":
        return "\x1B[34m"
    elif arg == "magenta":
        return "\x1B[35m"
    elif arg == "cyan":
        return "\x1B[36m"
    elif arg == "white":
        return "\x1B[37m"
    elif arg == "bright-black" or arg == "grey" or arg == "gray":
        return "\x1B[90m"
    elif arg == "bright-red":
        return "\x1B[91m"
    elif arg == "bright-green":
        return "\x1B[92m"
    elif arg == "bright-yellow":
        return "\x1B[93m"
    elif arg == "bright-blue":
        return "\x1B[94m"
    elif arg == "bright-magenta":
        return "\x1B[95m"
    elif arg == "bright-cyan":
        return "\x1B[96m"
    elif arg == "bright-white":
        return "\x1B[97m"
    else:
        return "\x1B[38;5;%sm" % arg

def parse_args(args):
    line_color = ""
    text_color = ""
    text = ""

    if len(args) == 1:
        return None, None, None
    elif len(args) == 2:
        text = args[1]
    elif len(args) == 3:
        line_color = get_color_code(args[1])
        text = args[2]
    elif len(args) == 4:
        line_color = get_color_code(args[1])
        text_color = get_color_code(args[2])
        text = args[3]
    else:
        return None, None, None

    return line_color, text_color, text

def main():
    if "-h" in sys.argv or "--help" in sys.argv:
        print(helptext)
        sys.exit()

    line_color, text_color, text = parse_args(sys.argv)

    if line_color is None:
        sys.exit(helptext)

    cols, _ = shutil.get_terminal_size()
    leading = math.floor((cols - len(text) - 4)/2)
    trailing = cols - len(text) - 4 - leading

    sys.stdout.write(line_color)
    sys.stdout.write("─" * cols + "\n ·" + "\x1B[39m")
    sys.stdout.write(text_color)
    sys.stdout.write(" " * leading + text + " " * trailing)
    sys.stdout.write(line_color)
    sys.stdout.write("· \n" + "─" * cols + "\n" + "\x1B[39m")

if __name__ == "__main__":
    main()
