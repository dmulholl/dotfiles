#!/usr/bin/env bash
set -euo pipefail

# Shortcut for 'git push', with protection for master/main.

branch_name=$(git branch --show-current)

if test "$branch_name" = "master" || test "$branch_name" = "main"; then
    echo "warning: in protected branch $branch_name, use gpm to push anyway"
    exit 1
fi

git push
