#!/usr/bin/env bash
set -euo pipefail

# ------------------------------------------------------------------------------
# Safe alternative to the 'rm' command. This script transfers deleted files
# and directories to the trash directory, $HOME/.trash/.
# ------------------------------------------------------------------------------

# The ~/.trash directory exists on OSX. We may need to create it on other systems.
if test ! -e "$HOME/.trash"; then
    mkdir "$HOME/.trash"
fi

# Move all our arguments to the trash directory.
for path in "$@"; do
    name=$(basename "$path")

    if test "$name" = "." || test "$name" = ".."; then
        echo "warning: skipping '$name'"
        continue
    fi

    if test ! -e "$path"; then
        echo "error: '$path' does not exist"
        continue
    fi


    while test -e "$HOME/.trash/$name"; do
        name="$name.$(date "+%Y-%m-%d.%H-%M-%S")"
    done

    mv "$path" "$HOME/.trash/$name"
done
